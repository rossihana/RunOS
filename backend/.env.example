# ============================================================
# RunOS Backend — Environment Variables
# Salin ke .env dan isi nilainya. JANGAN commit .env ke Git!
# ============================================================

NODE_ENV=production

# Strava API (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=ISI_CLIENT_ID_KAMU
STRAVA_CLIENT_SECRET=ISI_CLIENT_SECRET_KAMU

# JWT Secret — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ISI_RANDOM_STRING_PANJANG

# Supabase / PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# URL frontend kamu (untuk CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# URL backend ini sendiri (untuk Strava OAuth callback)
APP_URL=https://your-backend.vercel.app
