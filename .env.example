# ============================================================
# RunOS — Environment Variables Template
# Salin file ini menjadi .env lalu isi nilai yang sesuai.
# JANGAN commit file .env ke Git!
# ============================================================

# ============================================================
# APP
# ============================================================
NODE_ENV=development
APP_URL=http://localhost:3000

# ============================================================
# STRAVA API
# Daftar di: https://www.strava.com/settings/api
# ============================================================
STRAVA_CLIENT_ID=ISI_CLIENT_ID_KAMU
STRAVA_CLIENT_SECRET=ISI_CLIENT_SECRET_KAMU

# ============================================================
# JWT SECRET
# String acak panjang untuk menandatangani token.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=ISI_RANDOM_STRING_PANJANG_DI_SINI

# ============================================================
# DATABASE (Supabase / PostgreSQL)
# Dapatkan dari: Supabase → Project Settings → Database → URI
# ============================================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
